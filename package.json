{
  "name": "eval-copilot",
  "version": "1.0.0",
  "description": "CLI tool to run a prompt N times via GitHub Copilot SDK and generate an HTML comparison report",
  "type": "module",
  "bin": {
    "eval-copilot": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.2.0",
    "commander": "^14.0.3",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
