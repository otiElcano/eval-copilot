{
  "name": "eval-copilot",
  "version": "1.0.0",
  "description": "CLI tool to run a prompt N times via GitHub Copilot SDK and generate an HTML comparison report",
  "type": "module",
  "bin": {
    "eval-copilot": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.1.26",
    "commander": "^12.1.0",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
