{
  "servers": {
    "time": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "mcp/time"],
      "type": "stdio",
      "tools": ["*"]
    },
    "kali_mcp": {
      "command": "/opt/mcp_venv/bin/python3",
      "args": [
        "/opt/mcp/kali/mcp_server.py",
        "--server",
        "http://127.0.0.1:5000/"
      ],
      "tools": ["*"]
    }
  }
}
